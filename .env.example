# NeuroGuard — Environment Variables
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
# -------------------------------------------------------------------------

# ---- LLM Provider API Keys ----
# Required from Step 10 onward (model interaction layer).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Optional: Local model endpoint (e.g. Ollama, vLLM) ----
# LOCAL_MODEL_URL=http://localhost:8000/v1

# ---- Data paths (optional — defaults to ./data and ./results) ----
# NEUROGUARD_DATA_DIR=./data
# NEUROGUARD_RESULTS_DIR=./results

# ---- Logging ----
# NEUROGUARD_LOG_LEVEL=INFO

# ---- Experiment guardrails ----
# Max concurrent model API requests (avoid rate-limit storms).
# NEUROGUARD_MAX_CONCURRENT=5
# Hard USD cost ceiling per experiment run. Runner aborts if exceeded.
# NEUROGUARD_COST_LIMIT_USD=10.0
